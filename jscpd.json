{
    "absolute": false,
    "blame": false,
    "exitCode": 0,
    "gitignore": true,
    "ignore": [
        "**/*.bin",
        "**/*.config.js",
        "**/*.config.mjs",
        "**/*.config.ts",
        "**/*.css",
        "**/*.d.ts",
        "**/*.eot",
        "**/*.gif",
        "**/*.gz",
        "**/*.html",
        "**/*.ico",
        "**/*.jpeg",
        "**/*.jpg",
        "**/*.json",
        "**/*.md",
        "**/*.png",
        "**/*.sass",
        "**/*.scss",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/*.svg",
        "**/*.tar",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.ttf",
        "**/*.wasm",
        "**/*.woff",
        "**/*.woff2",
        "**/*.xml",
        "**/*.zip",
        "**/.git/**",
        "**/.github/**",
        "**/assets/**",
        "**/babel*",
        "**/babel-**",
        "**/benchmarks/**",
        "**/build/**",
        "**/commitlint*",
        "**/commitlint-**",
        "**/coverage/**",
        "**/dist/**",
        "**/docs/**",
        "**/electron/test/**",
        "**/eslint*",
        "**/eslint-**",
        "**/eslint-config*",
        "**/eslint-formatter*",
        "**/eslint-plugin*",
        "**/eslint-processor*",
        "**/eslint-reporter*",
        "**/grunt*",
        "**/grunt-**",
        "**/gulp*",
        "**/gulp-**",
        "**/html/**",
        "**/husky*",
        "**/husky-**",
        "**/icons/**",
        "**/lerna.json",
        "**/libs/**",
        "**/lint-staged*",
        "**/lint-staged-**",
        "**/node_modules/**",
        "**/package-lock.json",
        "**/pnpm-lock.yaml",
        "**/prettier*",
        "**/prettier-**",
        "**/release/**",
        "**/report/**",
        "**/rollup*",
        "**/rollup-**",
        "**/scripts/**",
        "**/src/test/**",
        "**/stylelint*",
        "**/stylelint-**",
        "**/test/**",
        "**/tests/**",
        "**/tsconfig.json",
        "**/vscode/**",
        "**/webpack*",
        "**/webpack-**",
        "**/yarn.lock"
    ],
    "ignoreCase": false,
    "maxLines": 10000,
    "maxSize": "100kb",
    "minLines": 10,
    "minTokens": 50,
    "mode": "mild",
    "noSymlinks": false,
    "output": "./reports/jscpd/",
    "pattern": "**/*",
    "reporters": [
        "html",
        "markdown",
        "json",
        "console",
        "xml",
        "csv"
    ],
    "reportersOptions": {
        "badge": {
            "color": "purple",
            "iconWidth": 13,
            "label": "jscpd",
            "style": "flat"
        }
    },
    "silent": false,
    "skipLocal": false,
    "threshold": 50,
    "verbose": false
}
